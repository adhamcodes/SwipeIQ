# Copy this file to ".env" and fill in your values.
# EXPO_PUBLIC_* variables are bundled into the app and visible to clients.
# The Supabase anon/publishable key is public by design — that's expected.
# Real protection comes from Row Level Security on your database tables.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Sentry crash reporting (optional but recommended for beta testing).
# Get this from sentry.io: Settings > Projects > [your project] > Client Keys (DSN).
# A Sentry DSN is safe to be public/client-side by design.
# If left blank, the app simply runs without crash reporting (no errors).
EXPO_PUBLIC_SENTRY_DSN=
