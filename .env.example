# Copy this file to ".env" and fill in your values.
# EXPO_PUBLIC_* variables are bundled into the app and visible to clients.
# The Supabase anon/publishable key is public by design — that's expected.
# Real protection comes from Row Level Security on your database tables.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
